# ─── Application ──────────────────────────────────────────────────────────────
# Base URL — used for canonical URLs, OG tags, sitemaps
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Contact / Email ──────────────────────────────────────────────────────────
# SMTP credentials for contact form (use a transactional email service)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=info@rhark.org

# ─── Newsletter ───────────────────────────────────────────────────────────────
# Mailchimp or similar — add when newsletter is implemented
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# ─── CMS (Future) ─────────────────────────────────────────────────────────────
# Sanity / Contentful — add when CMS is integrated
CMS_API_URL=
CMS_API_TOKEN=

# ─── Donation Gateway (Future) ────────────────────────────────────────────────
# M-Pesa Daraja API credentials
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# ─── Analytics (Future) ───────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
